generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Category {
  DSA
  GD
  MOCK_INTERVIEW
  PROJECT_WORK
  CURRENT_AFFAIRS
  JAPANESE
  COMMUNICATION
  READING
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum GDTopicCategory {
  ABSTRACT
  CURRENT_AFFAIRS
  BUSINESS
  TECHNICAL
  ETHICAL
}

enum InterviewType {
  HR
  TECHNICAL
  SYSTEM_DESIGN
}

enum CompanyStatus {
  APPLIED
  OA_RECEIVED
  OA_SUBMITTED
  INTERVIEW_R1
  INTERVIEW_R2
  INTERVIEW_R3
  HR_ROUND
  OFFER_RECEIVED
  REJECTED
  WITHDRAWN
}

enum RoundType {
  OA
  HR
  TECHNICAL
  SYSTEM_DESIGN
  MANAGERIAL
  CASE_STUDY
}

enum RoundOutcome {
  CLEARED
  REJECTED
  PENDING
}

// ─── Auth (NextAuth v4) ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  studySessions     StudySession[]
  dailyReports      DailyReport[]
  streaks           Streak[]
  targets           Target[]
  projects          Project[]
  milestones        Milestone[]
  journalEntries    JournalEntry[]
  pushSubscriptions  PushSubscription[]
  settings           UserSettings?
  gdTopics           GDTopic[]
  gdSessions         GDSession[]
  interviewQuestions InterviewQuestion[]
  questionAttempts   QuestionAttempt[]
  companies          Company[]
  dsaSkills          DSASkill[]
  friendships        Friendship[] @relation("AddedFriends")
  followedBy         Friendship[] @relation("AddedByUser")
  contestReminders   ContestReminder[]
  weeklyReports      WeeklyReport[]
  phoneUsageLogs     PhoneUsageLog[]
}

// ─── User Settings ────────────────────────────────────────────────────────────

model UserSettings {
  id               String  @id @default(cuid())
  userId           String  @unique
  notifMorning     Boolean @default(true)
  notifAfternoon   Boolean @default(true)
  notifEvening     Boolean @default(true)
  notifStreak      Boolean @default(true)
  morningTime      String  @default("08:00")
  eveningTime      String  @default("21:00")
  weeklySchedule   String?  // JSON: { "1": ["DSA","GD"], "2": [...], ... }
  githubUsername   String?
  cfHandle         String?
  lcHandle         String?
  isPublic         Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DSASkill {
  id            String   @id @default(cuid())
  userId        String
  topic         String
  level         Int      @default(0) // 0=unexplored 1=practicing 2=comfortable 3=strong 4=mastered
  practiceCount Int      @default(0)
  lastPracticed DateTime?
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topic])
}

// ─── Phone Usage Logs ────────────────────────────────────────────────────────

model PhoneUsageLog {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  totalMins   Int
  unlockCount Int
  topApps     String   // JSON: [{name,mins,visits}]
  categories  String   // JSON: [{name,mins,pct}]
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ─── Friendships ──────────────────────────────────────────────────────────────

// ─── Contest Reminders ────────────────────────────────────────────────────────

// ─── Weekly AI Report ─────────────────────────────────────────────────────────

model WeeklyReport {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime
  stats     String   // JSON: sessions, minutes, activeDays, scores
  aiSummary String   // Full AI narrative (multi-paragraph)
  strengths String   // JSON: string[]
  gaps      String   // JSON: string[]
  nextWeek  String   // JSON: string[]
  motNote   String   // One-liner motivational close
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
}

// ─── Contest Reminders ────────────────────────────────────────────────────────

model ContestReminder {
  id          String   @id @default(cuid())
  userId      String
  contestId   Int
  contestName String
  startTime   DateTime
  remindAt    DateTime
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId])
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())

  user   User @relation("AddedFriends", fields: [userId],   references: [id], onDelete: Cascade)
  friend User @relation("AddedByUser",  fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Study Session ────────────────────────────────────────────────────────────
// Renamed from "Session" to avoid conflict with NextAuth session table.
// SQL table name kept as "Session" via @@map.

model StudySession {
  id              String    @id @default(cuid())
  userId          String
  category        Category
  subcategory     String?
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int
  notes           String
  selfRating      Int
  metadata        String?   // JSON stored as text
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Session")
}

// ─── Daily Report ─────────────────────────────────────────────────────────────

model DailyReport {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime
  overallScore    Float
  categoryScores  String   // JSON stored as text
  summary         String
  strengths       String
  gaps            String
  recommendations String
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ─── Streak ───────────────────────────────────────────────────────────────────

model Streak {
  id               String   @id @default(cuid())
  userId           String
  category         Category
  currentStreak    Int      @default(0)
  bestStreak       Int      @default(0)
  lastActivityDate DateTime
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

// ─── Monthly Target ───────────────────────────────────────────────────────────

model Target {
  id           String   @id @default(cuid())
  userId       String
  month        Int
  year         Int
  category     Category
  targetValue  Int
  currentValue Int      @default(0)
  unit         String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year, category])
}

// ─── Project ──────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String
  color       String   @default("#6B8F71")
  repoUrl     String?  // "owner/repo" e.g. "amankumarsingh23/KaizenOS"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones Milestone[]
}

// ─── Milestone ────────────────────────────────────────────────────────────────

model Milestone {
  id            String          @id @default(cuid())
  userId        String
  projectId     String?         // nullable for backward compatibility
  projectName   String
  phase         String?         // e.g. "Phase 1: B-Tree Storage Engine"
  title         String
  description   String
  startDate     DateTime?       // for Gantt chart
  targetDate    DateTime
  completedDate DateTime?
  status        MilestoneStatus @default(PENDING)
  displayOrder  Int
  createdAt     DateTime        @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Journal ──────────────────────────────────────────────────────────────────

model JournalEntry {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime
  content        String
  mood           Int
  energy         Int
  // Phone usage
  screenTimeMins Int?
  pickupCount    Int?
  // Body metrics
  weightKg       Float?
  sleepHours     Float?
  proteinGrams   Int?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ─── Push Subscriptions ───────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
}

// ─── GD Topic Bank ────────────────────────────────────────────────────────────

model GDTopic {
  id              String          @id @default(cuid())
  userId          String?
  category        GDTopicCategory
  topic           String
  practiced       Boolean         @default(false)
  practiceCount   Int             @default(0)
  lastPracticedAt DateTime?
  bestScore       Int?

  user     User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions GDSession[]
}

// ─── GD Practice Sessions ─────────────────────────────────────────────────────

model GDSession {
  id             String   @id @default(cuid())
  topicId        String
  userId         String
  date           DateTime @default(now())
  score          Int?
  durationMin    Int?
  groupSize      Int?
  keyArgument    String?
  whatWentWell   String?
  whatToImprove  String?
  initiated      Boolean  @default(false)
  concluded      Boolean  @default(false)
  createdAt      DateTime @default(now())

  topic GDTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Interview Question Bank ──────────────────────────────────────────────────

model InterviewQuestion {
  id              String        @id @default(cuid())
  userId          String?
  type            InterviewType
  question        String
  preparedAnswer  String?
  practiced       Boolean       @default(false)
  practiceCount   Int           @default(0)
  lastPracticedAt DateTime?

  user     User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts QuestionAttempt[]
}

// ─── Interview Question Attempts ──────────────────────────────────────────────

model QuestionAttempt {
  id            String   @id @default(cuid())
  questionId    String
  userId        String
  date          DateTime @default(now())
  rating        Int
  notes         String
  whatWentWell  String?
  whatToImprove String?

  question InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Placement Pipeline ───────────────────────────────────────────────────────

model Company {
  id          String        @id @default(cuid())
  userId      String
  name        String
  role        String
  source      String?
  appliedDate DateTime
  status      CompanyStatus @default(APPLIED)
  ctc         String?
  resumeLabel String?       // e.g. "Resume_SDE_v3", "ML_Resume_Jan"
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  rounds CompanyRound[]
}

model CompanyRound {
  id        String       @id @default(cuid())
  companyId String
  type      RoundType
  date      DateTime?
  duration  Int?
  outcome   RoundOutcome @default(PENDING)
  notes     String?
  createdAt DateTime     @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
