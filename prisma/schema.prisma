generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Category {
  DSA
  GD
  MOCK_INTERVIEW
  PROJECT_WORK
  CURRENT_AFFAIRS
  JAPANESE
  COMMUNICATION
  READING
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum GDTopicCategory {
  ABSTRACT
  CURRENT_AFFAIRS
  BUSINESS
  TECHNICAL
  ETHICAL
}

enum InterviewType {
  HR
  TECHNICAL
  SYSTEM_DESIGN
}

// ─── Auth (NextAuth v4) ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  studySessions     StudySession[]
  dailyReports      DailyReport[]
  streaks           Streak[]
  targets           Target[]
  projects          Project[]
  milestones        Milestone[]
  journalEntries    JournalEntry[]
  pushSubscriptions PushSubscription[]
  settings          UserSettings?
}

// ─── User Settings ────────────────────────────────────────────────────────────

model UserSettings {
  id               String  @id @default(cuid())
  userId           String  @unique
  notifMorning     Boolean @default(true)
  notifAfternoon   Boolean @default(true)
  notifEvening     Boolean @default(true)
  notifStreak      Boolean @default(true)
  morningTime      String  @default("08:00")
  eveningTime      String  @default("21:00")
  weeklySchedule   String?  // JSON: { "1": ["DSA","GD"], "2": [...], ... }
  githubUsername   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Study Session ────────────────────────────────────────────────────────────
// Renamed from "Session" to avoid conflict with NextAuth session table.
// SQL table name kept as "Session" via @@map.

model StudySession {
  id              String    @id @default(cuid())
  userId          String
  category        Category
  subcategory     String?
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int
  notes           String
  selfRating      Int
  metadata        String?   // JSON stored as text
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Session")
}

// ─── Daily Report ─────────────────────────────────────────────────────────────

model DailyReport {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime
  overallScore    Float
  categoryScores  String   // JSON stored as text
  summary         String
  strengths       String
  gaps            String
  recommendations String
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ─── Streak ───────────────────────────────────────────────────────────────────

model Streak {
  id               String   @id @default(cuid())
  userId           String
  category         Category
  currentStreak    Int      @default(0)
  bestStreak       Int      @default(0)
  lastActivityDate DateTime
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

// ─── Monthly Target ───────────────────────────────────────────────────────────

model Target {
  id           String   @id @default(cuid())
  userId       String
  month        Int
  year         Int
  category     Category
  targetValue  Int
  currentValue Int      @default(0)
  unit         String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year, category])
}

// ─── Project ──────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String
  color       String   @default("#6B8F71")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones Milestone[]
}

// ─── Milestone ────────────────────────────────────────────────────────────────

model Milestone {
  id            String          @id @default(cuid())
  userId        String
  projectId     String?         // nullable for backward compatibility
  projectName   String
  phase         String?         // e.g. "Phase 1: B-Tree Storage Engine"
  title         String
  description   String
  startDate     DateTime?       // for Gantt chart
  targetDate    DateTime
  completedDate DateTime?
  status        MilestoneStatus @default(PENDING)
  displayOrder  Int
  createdAt     DateTime        @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Journal ──────────────────────────────────────────────────────────────────

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  content   String
  mood      Int
  energy    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ─── Push Subscriptions ───────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
}

// ─── GD Topic Bank ────────────────────────────────────────────────────────────

model GDTopic {
  id              String          @id @default(cuid())
  category        GDTopicCategory
  topic           String
  practiced       Boolean         @default(false)
  practiceCount   Int             @default(0)
  lastPracticedAt DateTime?
  bestScore       Int?
}

// ─── Interview Question Bank ──────────────────────────────────────────────────

model InterviewQuestion {
  id              String        @id @default(cuid())
  type            InterviewType
  question        String
  preparedAnswer  String?
  practiced       Boolean       @default(false)
  practiceCount   Int           @default(0)
  lastPracticedAt DateTime?
}
